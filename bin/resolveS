#!/bin/bash

#===============================================================================
# Script: resolveS
# Description: Default version of resolveS using paired-end alignment
# Usage:
#   Single file mode: ./resolveS -1 <R1.fq> -2 <R2.fq> [-o <output_file>]
#   Batch mode: ./resolveS -b <metadata_file> [-o <output_file>]
#===============================================================================
export PS4='+ ${BASH_SOURCE}:${LINENO}: '
#set -x
#
set -e

# Default values
MODE=""
R1_FILE=""
R2_FILE=""
METADATA_FILE=""
SAM_FILE=""  # Pre-aligned SAM file (use with -a option)
OUTPUT_FILE=""  # Empty means output to stdout
THREADS=6
MAX_ALIG_READS=5
MAX_ALIG_READS_ACTUAL=$((MAX_ALIG_READS * 1000000))
REFERENCE_DB="../ref_default/default"
REFERENCE_DB_IS_DEFAULT=true
DEBUG=false  # Debug mode: keep intermediate files
# Get the DIR of the SCRIPT
SCRIPT_DIR="$( cd "$( dirname "${BASH_SOURCE[0]}" )" &> /dev/null && pwd )"

# Color output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

#===============================================================================
# Functions
#===============================================================================

print_usage() {
    cat << 'EOF'
This is resolveS version 0.1.3
Usage: $0 [OPTIONS]

Options:
    -1 <file>       R1 (first read) file for single sample mode
    -2 <file>       R2 (second read) file for single sample mode
    -a <file>       Pre-aligned SAM file mode: skip alignment, use existing SAM file
    -b <file>       Batch mode: process multiple files from metadata file
                    - FASTQ batch: 2 columns (R1_path, R2_path)
                    - SAM batch: 1 column (SAM_path)
    -o <file>       Output the inference results to the file (default: stdout)
    -p <number>     Number of threads to use (default: 6)
    -u <number>     Maximum number of read pairs to align, in millions (default: 5, i.e. 5M pairs)
    -r <path>       The reference genome db, can be any bowtie2 index (default: ../ref_default/default)
    -d              Debug mode: keep intermediate files (resolveS.sam)
    -h              Show this help message

Examples:
    # Single sample mode (paired-end)
    $0 -1 sample_R1.fastq -2 sample_R2.fastq

    # Output to file
    $0 -1 sample_R1.fastq -2 sample_R2.fastq -o results.txt

    # Use pre-aligned SAM file (skip alignment step)
    $0 -a aligned.sam

    # Batch mode with FASTQ files
    $0 -b metadata_fastq.txt -p 8

    # Batch mode with SAM files
    $0 -b metadata_sam.txt

    # Limit alignment to 2 million read pairs
    $0 -1 sample_R1.fastq -2 sample_R2.fastq -u 2

IMPORTANT: This version uses paired-end alignment.
           For single-end data, use resolveS_fast instead.
           Use -a option if you already have a SAM file from alignment.

Metadata file format for FASTQ batch (tab-separated: R1_path R2_path):
    /path/to/sample1_R1.fastq    /path/to/sample1_R2.fastq
    /path/to/sample2_R1.fq.gz    /path/to/sample2_R2.fq.gz

Metadata file format for SAM batch (one path per line):
    /path/to/sample1.sam
    /path/to/sample2.sam

EOF
}

log_info() {
    local message="${1:-}"
    [[ -n "$message" ]] && echo -e "${GREEN}[INFO]${NC} $message" >&2
}

log_warn() {
    local message="${1:-}"
    [[ -n "$message" ]] && echo -e "${YELLOW}[WARN]${NC} $message" >&2
}

log_error() {
    local message="${1:-}"
    [[ -n "$message" ]] && echo -e "${RED}[ERROR]${NC} $message" >&2
}

check_dependencies() {
    local missing=0

    # Skip alignment dependencies check if using pre-aligned SAM file
    if [[ -z "$SAM_FILE" ]]; then
        if [[ ! -f "${REFERENCE_DB}.1.bt2" ]]; then
            log_error "Can not found the bowtie2 genome index file: ${REFERENCE_DB}.1.bt2"
            log_error "Please check your -r parameter or download the default index from https://github.com/yudalang3/resolveS"
            missing=1
        fi

        if [[ ! -f "${SCRIPT_DIR}/default_align_by_bowtie2.sh" ]]; then
            log_error "Required script not found: ${SCRIPT_DIR}/default_align_by_bowtie2.sh"
            missing=1
        fi
    fi

    if [[ ! -f "${SCRIPT_DIR}/default_counting_withChrom.pl" ]]; then
        log_error "Required script not found: ${SCRIPT_DIR}/default_counting_withChrom.pl"
        missing=1
    fi

    if [[ $missing -eq 1 ]]; then
        exit 1
    fi
}

process_single_sample() {
    local r1="$1"
    local r2="$2"
    local output="$3"
    local threads="$4"
    local max_alig_reads="$5"

    if [[ ! -f "$r1" ]]; then
        log_error "R1 file not found: $r1"
        return 1
    fi

    if [[ ! -f "$r2" ]]; then
        log_error "R2 file not found: $r2"
        return 1
    fi

    log_info "Processing paired-end: $r1 + $r2 (threads: $threads, max_pairs: ${MAX_ALIG_READS}M, reference: $REFERENCE_DB)"

    # Step 1: Run paired-end alignment
    "${SCRIPT_DIR}/default_align_by_bowtie2.sh" "$r1" "$r2" "$REFERENCE_DB" "$threads" "$max_alig_reads"

    # Get basename for logging (use R1 as identifier)
    local fullpath=$(realpath "$r1")

    # Step 2: Count and analyze strand with default_counting_withChrom.pl
    # Parameters: <input_sam_file> [output_file] [index_str] [debug=0]
    local debug_flag=0
    if [[ "$DEBUG" == true ]]; then
        debug_flag=1
    fi

    # If output is empty, use "-" for stdout
    local output_target="${output:--}"

    perl "${SCRIPT_DIR}/default_counting_withChrom.pl" resolveS.sam "$output_target" "$fullpath" "$debug_flag"
    return 0
}

process_prealigned_sam() {
    local sam_file="$1"
    local output="$2"

    if [[ ! -f "$sam_file" ]]; then
        log_error "SAM file not found: $sam_file"
        return 1
    fi

    log_info "Processing pre-aligned SAM file: $sam_file"

    # Get absolute path for logging
    local fullpath=$(realpath "$sam_file")

    # Count and analyze strand with default_counting_withChrom.pl
    # Parameters: <input_sam_file> [output_file] [index_str] [debug=0]
    local debug_flag=0
    if [[ "$DEBUG" == true ]]; then
        debug_flag=1
    fi

    # If output is empty, use "-" for stdout
    local output_target="${output:--}"

    perl "${SCRIPT_DIR}/default_counting_withChrom.pl" "$fullpath" "$output_target" "$fullpath" "$debug_flag"
    return 0
}

process_batch() {
    local metadata="$1"
    local output_file="$2"
    local threads="$3"
    local max_alig_reads="$4"

    if [[ ! -f "$metadata" ]]; then
        log_error "Metadata file not found: $metadata"
        exit 1
    fi

    # Count non-empty, non-comment lines
    local total_lines=$(grep -v '^[[:space:]]*#' "$metadata" | grep -v '^[[:space:]]*$' | wc -l)

    local current=0
    local success=0
    local failed=0

    log_info "Starting batch processing of $total_lines samples (threads: $threads, max_pairs: ${MAX_ALIG_READS}M)"

    # Output header before processing
    if [[ -z "$output_file" ]]; then
        # stdout mode - always output header
        echo -e "index_str\tstrand_type\tMAPQ_filter\tdetection_level\tfwd\trev\tfwd_Ratio\trev_Ratio\tRel_Diff"
    elif [[ ! -s "$output_file" ]]; then
        # file mode - output header if file doesn't exist or is empty
        echo -e "index_str\tstrand_type\tMAPQ_filter\tdetection_level\tfwd\trev\tfwd_Ratio\trev_Ratio\tRel_Diff" > "$output_file"
    fi

    while IFS=$'\t' read -r r1_file r2_file || [[ -n "$r1_file" ]]; do
        # Skip empty lines
        if [[ -z "$r1_file" ]]; then
            continue
        fi
        # Skip comments
        if [[ "$r1_file" =~ ^# ]]; then
            continue
        fi

        ((current++)) || true
        log_info "Processing sample $current/$total_lines"

        process_single_sample "$r1_file" "$r2_file" "$output_file" "$threads" "$max_alig_reads"
        local result=$?

        if [[ $result -eq 0 ]]; then
            ((success++)) || true
        else
            ((failed++)) || true
            log_error "Failed to process: $r1_file"
        fi

    done < "$metadata"

    log_info "Batch processing completed!"
    log_info "Total: $total_lines | Success: $success | Failed: $failed"
}

process_batch_sam() {
    local metadata="$1"
    local output_file="$2"

    if [[ ! -f "$metadata" ]]; then
        log_error "Metadata file not found: $metadata"
        exit 1
    fi

    # Count non-empty, non-comment lines
    local total_lines=$(grep -v '^[[:space:]]*#' "$metadata" | grep -v '^[[:space:]]*$' | wc -l)

    local current=0
    local success=0
    local failed=0

    log_info "Starting batch SAM processing of $total_lines samples"

    # Output header before processing
    if [[ -z "$output_file" ]]; then
        # stdout mode - always output header
        echo -e "index_str\tstrand_type\tMAPQ_filter\tdetection_level\tfwd\trev\tfwd_Ratio\trev_Ratio\tRel_Diff"
    elif [[ ! -s "$output_file" ]]; then
        # file mode - output header if file doesn't exist or is empty
        echo -e "index_str\tstrand_type\tMAPQ_filter\tdetection_level\tfwd\trev\tfwd_Ratio\trev_Ratio\tRel_Diff" > "$output_file"
    fi

    while IFS= read -r sam_file || [[ -n "$sam_file" ]]; do
        # Skip empty lines
        if [[ -z "$sam_file" ]]; then
            continue
        fi
        # Skip comments
        if [[ "$sam_file" =~ ^# ]]; then
            continue
        fi

        ((current++)) || true
        log_info "Processing SAM file $current/$total_lines"

        process_prealigned_sam "$sam_file" "$output_file"
        local result=$?

        if [[ $result -eq 0 ]]; then
            ((success++)) || true
        else
            ((failed++)) || true
            log_error "Failed to process: $sam_file"
        fi

    done < "$metadata"

    log_info "Batch SAM processing completed!"
    log_info "Total: $total_lines | Success: $success | Failed: $failed"
}

#===============================================================================
# Main
#===============================================================================

# Parse command line arguments
while getopts "1:2:a:b:o:p:u:r:dh" opt; do
    case $opt in
        1)
            MODE="single"
            R1_FILE="$OPTARG"
            ;;
        2)
            R2_FILE="$OPTARG"
            ;;
        a)
            MODE="sam"
            SAM_FILE="$OPTARG"
            ;;
        b)
            MODE="batch"
            METADATA_FILE="$OPTARG"
            ;;
        o)
            OUTPUT_FILE="$OPTARG"
            ;;
        p)
            THREADS="$OPTARG"
            if ! [[ "$THREADS" =~ ^[0-9]+$ ]] || [[ "$THREADS" -lt 1 ]]; then
                log_error "Invalid thread number: $THREADS (must be a positive integer)"
                exit 1
            fi
            ;;
        u)
            MAX_ALIG_READS="$OPTARG"
            if ! [[ "$MAX_ALIG_READS" =~ ^[0-9]+$ ]] || [[ "$MAX_ALIG_READS" -lt 1 ]]; then
                log_error "Invalid -u value: $MAX_ALIG_READS (must be a positive integer, unit: millions)"
                exit 1
            fi
            MAX_ALIG_READS_ACTUAL=$((MAX_ALIG_READS * 1000000))
            ;;
        r)
            REFERENCE_DB="$OPTARG"
            REFERENCE_DB_IS_DEFAULT=false
            ;;
        d)
            DEBUG=true
            ;;
        h)
            print_usage
            exit 0
            ;;
        \?)
            log_error "Invalid option: -$OPTARG"
            print_usage
            exit 1
            ;;
    esac
done

# Normalize REFERENCE_DB to absolute path
if [[ "$REFERENCE_DB" != /* ]]; then
    if [[ "$REFERENCE_DB_IS_DEFAULT" == true ]]; then
        REFERENCE_DB="${SCRIPT_DIR}/${REFERENCE_DB}"
    else
        if [[ -d "$(dirname "$REFERENCE_DB")" ]]; then
            REFERENCE_DB="$(cd "$(dirname "$REFERENCE_DB")" && pwd)/$(basename "$REFERENCE_DB")"
        else
            REFERENCE_DB="$(pwd)/$REFERENCE_DB"
        fi
    fi
fi

# Check if mode is specified
if [[ -z "$MODE" ]]; then
    log_error "Please specify either -1/-2 (single sample), -a (pre-aligned SAM), or -b (batch) mode"
    print_usage
    exit 1
fi

# Check dependencies
check_dependencies

# Execute based on mode
case $MODE in
    single)
        if [[ -z "$R1_FILE" ]] || [[ -z "$R2_FILE" ]]; then
            log_error "Both -1 (R1) and -2 (R2) files must be specified for single sample mode"
            exit 1
        fi

        # Output header before processing
        if [[ -z "$OUTPUT_FILE" ]]; then
            # stdout mode - always output header
            echo -e "index_str\tstrand_type\tMAPQ_filter\tdetection_level\tfwd\trev\tfwd_Ratio\trev_Ratio\tRel_Diff"
        elif [[ ! -s "$OUTPUT_FILE" ]]; then
            # file mode - output header if file doesn't exist or is empty
            echo -e "index_str\tstrand_type\tMAPQ_filter\tdetection_level\tfwd\trev\tfwd_Ratio\trev_Ratio\tRel_Diff" > "$OUTPUT_FILE"
        fi

        process_single_sample "$R1_FILE" "$R2_FILE" "$OUTPUT_FILE" "$THREADS" "$MAX_ALIG_READS_ACTUAL"
        ;;
    sam)
        if [[ -z "$SAM_FILE" ]]; then
            log_error "SAM file not specified for -a mode"
            exit 1
        fi

        # Output header before processing
        if [[ -z "$OUTPUT_FILE" ]]; then
            # stdout mode - always output header
            echo -e "index_str\tstrand_type\tMAPQ_filter\tdetection_level\tfwd\trev\tfwd_Ratio\trev_Ratio\tRel_Diff"
        elif [[ ! -s "$OUTPUT_FILE" ]]; then
            # file mode - output header if file doesn't exist or is empty
            echo -e "index_str\tstrand_type\tMAPQ_filter\tdetection_level\tfwd\trev\tfwd_Ratio\trev_Ratio\tRel_Diff" > "$OUTPUT_FILE"
        fi

        process_prealigned_sam "$SAM_FILE" "$OUTPUT_FILE"
        ;;
    batch)
        if [[ -z "$METADATA_FILE" ]]; then
            log_error "Metadata file not specified for batch mode"
            exit 1
        fi

        # Auto-detect metadata format: 2 columns = FASTQ, 1 column = SAM
        # Read first non-empty, non-comment line to detect format
        FIRST_LINE=$(grep -v '^[[:space:]]*#' "$METADATA_FILE" | grep -v '^[[:space:]]*$' | head -1)
        COLUMN_COUNT=$(echo "$FIRST_LINE" | awk -F'\t' '{print NF}')

        if [[ $COLUMN_COUNT -eq 2 ]]; then
            log_info "Detected FASTQ batch mode (2 columns in metadata)"
            process_batch "$METADATA_FILE" "$OUTPUT_FILE" "$THREADS" "$MAX_ALIG_READS_ACTUAL"
        elif [[ $COLUMN_COUNT -eq 1 ]]; then
            log_info "Detected SAM batch mode (1 column in metadata)"
            process_batch_sam "$METADATA_FILE" "$OUTPUT_FILE"
        else
            log_error "Invalid metadata format. Expected 2 columns (R1, R2) for FASTQ or 1 column for SAM files"
            exit 1
        fi
        ;;
esac


# Clean up (skip if debug mode)
if [[ "$DEBUG" == false ]]; then
    if [[ -f resolveS.sam ]]; then
        rm resolveS.sam
        log_info "Cleaned up temporary file: resolveS.sam"
    fi
else
    log_info "Debug mode: keeping intermediate file (resolveS.sam)"
fi

log_info "All done!"

exit 0
