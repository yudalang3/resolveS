#!/bin/bash

#===============================================================================
# Script: resolveS
# Description: RNA-seq strandedness detection for single-end/paired-end FASTQ
#              and explicitly typed pre-aligned SAM input.
#===============================================================================
export PS4='+ ${BASH_SOURCE}:${LINENO}: '
set -e

# Default values
INPUT_KIND=""             # fastq_single | fastq_pair | sam | batch
BATCH_KIND=""             # fastq_single | fastq_pair | sam
SAM_MODE=""               # single | pair
M_OPTION=""               # raw -m value: 1 | 2
R1_FILE=""
R2_FILE=""
METADATA_FILE=""
SAM_FILE=""
OUTPUT_FILE=""
THREADS=8
MAX_ALIG_READS=5
MAX_ALIG_READS_ACTUAL=$((MAX_ALIG_READS * 1000000))
REFERENCE_DB="../ref_default/default"
REFERENCE_DB_IS_DEFAULT=true
DEBUG=false
THREADS_SET=false
MAX_ALIG_READS_SET=false
CURRENT_BATCH_INDEX=0
SCRIPT_DIR="$( cd "$( dirname "${BASH_SOURCE[0]}" )" &> /dev/null && pwd )"
OUTPUT_HEADER="File\tStrand_Type\tMAPQ_Filter\tDetection_Level\tOverall_fallback_Fwd\tOverall_fallback_Rev\tOverall_fallback_Fwd_Ratio\tOverall_fallback_Rev_Ratio\tOverall_fallback_Rel_Diff"

# Color output only when stderr is a terminal.
if [[ -t 2 ]]; then
    RED='\033[0;31m'
    GREEN='\033[0;32m'
    YELLOW='\033[1;33m'
    NC='\033[0m' # No Color
else
    RED=''
    GREEN=''
    YELLOW=''
    NC=''
fi

#===============================================================================
# Functions
#===============================================================================

print_usage() {
    cat << 'EOF'
This is resolveS version 0.2.0
Usage: $0 [OPTIONS]

Options:
    -1 <file>       FASTQ read file. With only -1, runs single-end FASTQ mode.
                    With -1 and -2, runs paired-end FASTQ mode.
    -2 <file>       R2 FASTQ file for paired-end FASTQ mode.
    -a <file>       Pre-aligned SAM file mode. Requires -m 1 or -m 2.
    -b <file>       Batch metadata file. All records must have the same input kind:
                    - 1 FASTQ column: single-end FASTQ batch
                    - 2 FASTQ columns: paired-end FASTQ batch
                    - 1 SAM column: SAM batch, requires -m 1 or -m 2
    -m <1|2>        SAM input mode only: 1 = single-end SAM, 2 = paired-end SAM.
                    Invalid for FASTQ input.
    -o <file>       Output the inference results to the file (default: stdout).
    -p <number>     Number of threads to use for FASTQ alignment (default: 8).
                    Ignored for SAM input.
    -u <number>     FASTQ alignment limit, in millions (default: 5).
                    Single-end FASTQ: maximum reads to align.
                    Paired-end FASTQ: maximum read pairs to align.
                    Ignored for SAM input.
    -r <path>       The reference genome db, can be any bowtie2 index
                    (default: ../ref_default/default).
    -d              Debug mode: keep intermediate SAM files and print counting details.
    -h              Show this help message.

Examples:
    # Single-end FASTQ
    $0 -1 sample.fastq.gz

    # Paired-end FASTQ
    $0 -1 R1.fastq.gz -2 R2.fastq.gz

    # Single-end SAM
    $0 -a aligned.sam -m 1

    # Paired-end SAM
    $0 -a aligned.sam -m 2

    # Single-end FASTQ batch: one FASTQ path per metadata row
    $0 -b batch_single_fastq_metadata.txt

    # Paired-end FASTQ batch: R1<TAB>R2 per metadata row
    $0 -b batch_pair_fastq_metadata.txt

    # SAM batch: one SAM path per metadata row, explicit SAM mode required
    $0 -b batch_sam_metadata.txt -m 1
    $0 -b batch_sam_metadata.txt -m 2

Notes:
    - FASTQ input mode is inferred from -1/-2 or batch metadata.
    - SAM input mode is never inferred; use -m 1 or -m 2.
    - -p and -u do not affect SAM input and will emit warnings when supplied.

EOF
}

log_info() {
    local message="${1:-}"
    [[ -n "$message" ]] && echo -e "${GREEN}[INFO]${NC} $message" >&2
}

log_warn() {
    local message="${1:-}"
    [[ -n "$message" ]] && echo -e "${YELLOW}[WARN]${NC} $message" >&2
}

log_error() {
    local message="${1:-}"
    [[ -n "$message" ]] && echo -e "${RED}[ERROR]${NC} $message" >&2
}

emit_header() {
    local output_file="$1"

    if [[ -z "$output_file" ]]; then
        echo -e "$OUTPUT_HEADER"
    elif [[ ! -s "$output_file" ]]; then
        echo -e "$OUTPUT_HEADER" > "$output_file"
    fi
}

count_effective_metadata_lines() {
    local metadata="$1"
    awk 'BEGIN { count = 0 } /^[[:space:]]*($|#)/ { next } { count++ } END { print count }' "$metadata"
}

detect_batch_kind() {
    local metadata="$1"

    if [[ ! -f "$metadata" ]]; then
        log_error "Metadata file not found: $metadata"
        return 1
    fi

    local expected=""
    local seen=0
    local line

    while IFS= read -r line || [[ -n "$line" ]]; do
        [[ "$line" =~ ^[[:space:]]*$ ]] && continue
        [[ "$line" =~ ^[[:space:]]*# ]] && continue

        ((seen++)) || true

        local column_count
        column_count=$(awk -F '\t' '{ print NF }' <<< "$line")

        local current=""
        if [[ "$column_count" -eq 2 ]]; then
            local col1=""
            local col2=""
            IFS=$'\t' read -r col1 col2 <<< "$line"
            if [[ -z "$col1" || -z "$col2" ]]; then
                log_error "Invalid metadata format: empty FASTQ column"
                return 1
            fi
            current="fastq_pair"
        elif [[ "$column_count" -eq 1 ]]; then
            local path="$line"
            local lower="${path,,}"
            if [[ "$lower" =~ \.sam$ ]]; then
                current="sam"
            elif [[ "$lower" =~ \.(fq|fastq)(\.gz)?$ ]]; then
                current="fastq_single"
            else
                log_error "Cannot detect metadata type from one-column path: $path"
                return 1
            fi
        else
            log_error "Invalid metadata format: expected 1 or 2 tab-separated columns"
            return 1
        fi

        if [[ -z "$expected" ]]; then
            expected="$current"
        elif [[ "$current" != "$expected" ]]; then
            log_error "Mixed metadata types are unsupported"
            return 1
        fi
    done < "$metadata"

    if [[ "$seen" -eq 0 ]]; then
        log_error "Metadata file has no samples: $metadata"
        return 1
    fi

    printf '%s\n' "$expected"
}

check_dependencies() {
    local kind="$1"
    local missing=0

    if [[ ! -f "${SCRIPT_DIR}/auto_counting_withChrom.pl" ]]; then
        log_error "Required script not found: ${SCRIPT_DIR}/auto_counting_withChrom.pl"
        missing=1
    fi

    case "$kind" in
        fastq_pair)
            if [[ ! -f "${REFERENCE_DB}.1.bt2" ]]; then
                log_error "Can not found the bowtie2 genome index file: ${REFERENCE_DB}.1.bt2"
                log_error "Please check your -r parameter or download the default index from https://github.com/yudalang3/resolveS"
                missing=1
            fi
            if [[ ! -f "${SCRIPT_DIR}/default_align_by_bowtie2.sh" ]]; then
                log_error "Required script not found: ${SCRIPT_DIR}/default_align_by_bowtie2.sh"
                missing=1
            fi
            ;;
        fastq_single)
            if [[ ! -f "${REFERENCE_DB}.1.bt2" ]]; then
                log_error "Can not found the bowtie2 genome index file: ${REFERENCE_DB}.1.bt2"
                log_error "Please check your -r parameter or download the default index from https://github.com/yudalang3/resolveS"
                missing=1
            fi
            if [[ ! -f "${SCRIPT_DIR}/default_align_single_by_bowtie2.sh" ]]; then
                log_error "Required script not found: ${SCRIPT_DIR}/default_align_single_by_bowtie2.sh"
                missing=1
            fi
            ;;
        sam)
            ;;
        *)
            log_error "Unknown dependency kind: $kind"
            missing=1
            ;;
    esac

    if [[ "$missing" -eq 1 ]]; then
        exit 1
    fi
}

make_sam_path() {
    local sample_index="${1:-0}"

    if [[ "$INPUT_KIND" == "batch" ]]; then
        printf 'resolveS.sample_%04d.sam\n' "$sample_index"
    else
        printf 'resolveS.sam\n'
    fi
}

cleanup_sam() {
    local sam_path="$1"

    if [[ "$DEBUG" == false ]]; then
        if [[ -f "$sam_path" ]]; then
            rm "$sam_path"
            log_info "Cleaned up temporary file: $sam_path"
        fi
    else
        log_info "Debug mode: keeping intermediate file: $sam_path"
    fi
}

process_fastq_single() {
    local read="$1"
    local output="$2"
    local threads="$3"
    local max_alig_reads="$4"
    local sam_path="$5"

    if [[ ! -f "$read" ]]; then
        log_error "FASTQ file not found: $read"
        return 1
    fi

    log_info "Processing single-end FASTQ: $read (threads: $threads, max_reads: ${MAX_ALIG_READS}M, reference: $REFERENCE_DB)"

    if ! "${SCRIPT_DIR}/default_align_single_by_bowtie2.sh" "$read" "$REFERENCE_DB" "$threads" "$max_alig_reads" "$sam_path"; then
        log_error "Single-end alignment failed: $read"
        cleanup_sam "$sam_path"
        return 1
    fi

    local fullpath
    fullpath=$(realpath "$read")

    local debug_flag=0
    [[ "$DEBUG" == true ]] && debug_flag=1

    local output_target="${output:--}"

    if ! perl "${SCRIPT_DIR}/auto_counting_withChrom.pl" "$sam_path" "$output_target" "$fullpath" "$debug_flag" single; then
        log_error "Single-end counting failed: $read"
        cleanup_sam "$sam_path"
        return 1
    fi

    cleanup_sam "$sam_path"
    return 0
}

process_fastq_pair() {
    local r1="$1"
    local r2="$2"
    local output="$3"
    local threads="$4"
    local max_alig_reads="$5"
    local sam_path="$6"

    if [[ ! -f "$r1" ]]; then
        log_error "R1 file not found: $r1"
        return 1
    fi

    if [[ ! -f "$r2" ]]; then
        log_error "R2 file not found: $r2"
        return 1
    fi

    log_info "Processing paired-end FASTQ: $r1 + $r2 (threads: $threads, max_pairs: ${MAX_ALIG_READS}M, reference: $REFERENCE_DB)"

    if ! "${SCRIPT_DIR}/default_align_by_bowtie2.sh" "$r1" "$r2" "$REFERENCE_DB" "$threads" "$max_alig_reads" "$sam_path"; then
        log_error "Paired-end alignment failed: $r1 + $r2"
        cleanup_sam "$sam_path"
        return 1
    fi

    local fullpath
    fullpath=$(realpath "$r1")

    local debug_flag=0
    [[ "$DEBUG" == true ]] && debug_flag=1

    local output_target="${output:--}"

    if ! perl "${SCRIPT_DIR}/auto_counting_withChrom.pl" "$sam_path" "$output_target" "$fullpath" "$debug_flag" pair; then
        log_error "Paired-end counting failed: $r1 + $r2"
        cleanup_sam "$sam_path"
        return 1
    fi

    cleanup_sam "$sam_path"
    return 0
}

process_prealigned_sam() {
    local sam_file="$1"
    local output="$2"
    local sam_mode="$3"

    if [[ ! -f "$sam_file" ]]; then
        log_error "SAM file not found: $sam_file"
        return 1
    fi

    if [[ "$sam_mode" != "single" && "$sam_mode" != "pair" ]]; then
        log_error "SAM mode is required for SAM input (-m 1 or -m 2)"
        return 1
    fi

    log_info "Processing pre-aligned SAM file: $sam_file (mode: $sam_mode)"

    local fullpath
    fullpath=$(realpath "$sam_file")

    local debug_flag=0
    [[ "$DEBUG" == true ]] && debug_flag=1

    local output_target="${output:--}"

    if ! perl "${SCRIPT_DIR}/auto_counting_withChrom.pl" "$fullpath" "$output_target" "$fullpath" "$debug_flag" "$sam_mode"; then
        log_error "SAM counting failed: $fullpath"
        return 1
    fi

    return 0
}

process_batch() {
    local metadata="$1"
    local output_file="$2"
    local threads="$3"
    local max_alig_reads="$4"
    local batch_kind="$5"
    local sam_mode="${6:-}"

    local total_lines
    total_lines=$(count_effective_metadata_lines "$metadata")

    local current=0
    local success=0
    local failed=0
    local line

    case "$batch_kind" in
        fastq_single)
            log_info "Starting single-end FASTQ batch processing of $total_lines samples (threads: $threads, max_reads: ${MAX_ALIG_READS}M)"
            ;;
        fastq_pair)
            log_info "Starting paired-end FASTQ batch processing of $total_lines samples (threads: $threads, max_pairs: ${MAX_ALIG_READS}M)"
            ;;
        sam)
            log_info "Starting SAM batch processing of $total_lines samples (mode: $sam_mode)"
            ;;
    esac

    emit_header "$output_file"

    while IFS= read -r line || [[ -n "$line" ]]; do
        [[ "$line" =~ ^[[:space:]]*$ ]] && continue
        [[ "$line" =~ ^[[:space:]]*# ]] && continue

        ((current++)) || true
        CURRENT_BATCH_INDEX="$current"
        log_info "Processing sample $current/$total_lines"

        case "$batch_kind" in
            fastq_single)
                local read_file="$line"
                local sam_path
                sam_path=$(make_sam_path "$current")

                if process_fastq_single "$read_file" "$output_file" "$threads" "$max_alig_reads" "$sam_path"; then
                    ((success++)) || true
                else
                    ((failed++)) || true
                    log_error "Failed to process sample $current: $read_file"
                fi
                ;;
            fastq_pair)
                local r1_file=""
                local r2_file=""
                IFS=$'\t' read -r r1_file r2_file <<< "$line"
                local sam_path
                sam_path=$(make_sam_path "$current")

                if process_fastq_pair "$r1_file" "$r2_file" "$output_file" "$threads" "$max_alig_reads" "$sam_path"; then
                    ((success++)) || true
                else
                    ((failed++)) || true
                    log_error "Failed to process sample $current: $r1_file"
                fi
                ;;
            sam)
                local sam_file="$line"

                if process_prealigned_sam "$sam_file" "$output_file" "$sam_mode"; then
                    ((success++)) || true
                else
                    ((failed++)) || true
                    log_error "Failed to process sample $current: $sam_file"
                fi
                ;;
        esac
    done < "$metadata"

    log_info "Batch processing completed!"
    log_info "Total: $total_lines | Success: $success | Failed: $failed"

    [[ "$failed" -eq 0 ]]
}

#===============================================================================
# Main
#===============================================================================

while getopts "1:2:a:b:o:p:u:r:m:dh" opt; do
    case $opt in
        1)
            R1_FILE="$OPTARG"
            ;;
        2)
            R2_FILE="$OPTARG"
            ;;
        a)
            SAM_FILE="$OPTARG"
            ;;
        b)
            METADATA_FILE="$OPTARG"
            ;;
        o)
            OUTPUT_FILE="$OPTARG"
            ;;
        p)
            THREADS="$OPTARG"
            THREADS_SET=true
            if ! [[ "$THREADS" =~ ^[0-9]+$ ]] || [[ "$THREADS" -lt 1 ]]; then
                log_error "Invalid thread number: $THREADS (must be a positive integer)"
                exit 1
            fi
            ;;
        u)
            MAX_ALIG_READS="$OPTARG"
            MAX_ALIG_READS_SET=true
            if ! [[ "$MAX_ALIG_READS" =~ ^[0-9]+$ ]] || [[ "$MAX_ALIG_READS" -lt 1 ]]; then
                log_error "Invalid -u value: $MAX_ALIG_READS (must be a positive integer, unit: millions)"
                exit 1
            fi
            if [[ "$MAX_ALIG_READS" -gt 100 ]]; then
                log_error "Invalid -u value: $MAX_ALIG_READS is too large. The unit is MILLIONS, so -u 5 means 5 million reads or read pairs. Typical values: 1-10."
                exit 1
            fi
            MAX_ALIG_READS_ACTUAL=$((MAX_ALIG_READS * 1000000))
            ;;
        r)
            REFERENCE_DB="$OPTARG"
            REFERENCE_DB_IS_DEFAULT=false
            ;;
        m)
            case "$OPTARG" in
                1)
                    M_OPTION="1"
                    SAM_MODE="single"
                    ;;
                2)
                    M_OPTION="2"
                    SAM_MODE="pair"
                    ;;
                *)
                    log_error "Invalid -m value: $OPTARG (must be 1 for single-end SAM or 2 for paired-end SAM)"
                    exit 1
                    ;;
            esac
            ;;
        d)
            DEBUG=true
            ;;
        h)
            print_usage
            exit 0
            ;;
        \?)
            log_error "Invalid option: -$OPTARG"
            print_usage
            exit 1
            ;;
    esac
done

# Normalize REFERENCE_DB to absolute path
if [[ "$REFERENCE_DB" != /* ]]; then
    if [[ "$REFERENCE_DB_IS_DEFAULT" == true ]]; then
        REFERENCE_DB="${SCRIPT_DIR}/${REFERENCE_DB}"
    else
        if [[ -d "$(dirname "$REFERENCE_DB")" ]]; then
            REFERENCE_DB="$(cd "$(dirname "$REFERENCE_DB")" && pwd)/$(basename "$REFERENCE_DB")"
        else
            REFERENCE_DB="$(pwd)/$REFERENCE_DB"
        fi
    fi
fi

# Mutually exclusive input checks
if [[ -n "$SAM_FILE" && ( -n "$R1_FILE" || -n "$R2_FILE" || -n "$METADATA_FILE" ) ]]; then
    log_error "-a cannot be used with -1, -2, or -b"
    exit 1
fi

if [[ -n "$METADATA_FILE" && ( -n "$R1_FILE" || -n "$R2_FILE" || -n "$SAM_FILE" ) ]]; then
    log_error "-b cannot be used with -1, -2, or -a"
    exit 1
fi

if [[ -n "$R2_FILE" && -z "$R1_FILE" ]]; then
    log_error "-2 cannot be used without -1"
    exit 1
fi

if [[ -n "$SAM_FILE" ]]; then
    INPUT_KIND="sam"
elif [[ -n "$METADATA_FILE" ]]; then
    INPUT_KIND="batch"
elif [[ -n "$R1_FILE" && -n "$R2_FILE" ]]; then
    INPUT_KIND="fastq_pair"
elif [[ -n "$R1_FILE" ]]; then
    INPUT_KIND="fastq_single"
else
    log_error "Please specify FASTQ (-1, optionally -2), SAM (-a with -m), or batch (-b)"
    print_usage
    exit 1
fi

if [[ "$INPUT_KIND" == "batch" ]]; then
    BATCH_KIND=$(detect_batch_kind "$METADATA_FILE")
fi

case "$INPUT_KIND" in
    sam)
        if [[ -z "$SAM_MODE" ]]; then
            log_error "SAM input requires -m 1 for single-end SAM or -m 2 for paired-end SAM"
            exit 1
        fi
        ;;
    fastq_single|fastq_pair)
        if [[ -n "$SAM_MODE" ]]; then
            log_error "-m is only valid for SAM input (-a or SAM batch)"
            exit 1
        fi
        ;;
    batch)
        if [[ "$BATCH_KIND" == "sam" ]]; then
            if [[ -z "$SAM_MODE" ]]; then
                log_error "SAM batch requires -m 1 for single-end SAM or -m 2 for paired-end SAM"
                exit 1
            fi
        elif [[ -n "$SAM_MODE" ]]; then
            log_error "-m is only valid for SAM input (-a or SAM batch)"
            exit 1
        fi
        ;;
esac

if [[ "$INPUT_KIND" == "sam" || ( "$INPUT_KIND" == "batch" && "$BATCH_KIND" == "sam" ) ]]; then
    [[ "$THREADS_SET" == true ]] && log_warn "-p is ignored for SAM input because no alignment is run"
    [[ "$MAX_ALIG_READS_SET" == true ]] && log_warn "-u is ignored for SAM input because no alignment is run"
fi

if [[ "$INPUT_KIND" == "batch" ]]; then
    check_dependencies "$BATCH_KIND"
else
    check_dependencies "$INPUT_KIND"
fi

case "$INPUT_KIND" in
    fastq_single)
        emit_header "$OUTPUT_FILE"
        sam_path=$(make_sam_path 0)
        if ! process_fastq_single "$R1_FILE" "$OUTPUT_FILE" "$THREADS" "$MAX_ALIG_READS_ACTUAL" "$sam_path"; then
            exit 1
        fi
        ;;
    fastq_pair)
        emit_header "$OUTPUT_FILE"
        sam_path=$(make_sam_path 0)
        if ! process_fastq_pair "$R1_FILE" "$R2_FILE" "$OUTPUT_FILE" "$THREADS" "$MAX_ALIG_READS_ACTUAL" "$sam_path"; then
            exit 1
        fi
        ;;
    sam)
        emit_header "$OUTPUT_FILE"
        if ! process_prealigned_sam "$SAM_FILE" "$OUTPUT_FILE" "$SAM_MODE"; then
            exit 1
        fi
        ;;
    batch)
        log_info "Detected batch kind: $BATCH_KIND"
        if ! process_batch "$METADATA_FILE" "$OUTPUT_FILE" "$THREADS" "$MAX_ALIG_READS_ACTUAL" "$BATCH_KIND" "$SAM_MODE"; then
            exit 1
        fi
        ;;
esac

log_info "All done!"

exit 0
