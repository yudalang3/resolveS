#!/bin/bash

#===============================================================================
# Script: resolveS_singlePrecise
# Description: Precise version of resolveS using paired-end alignment with 1M incremental analysis
# Usage:
#   Single file mode: ./resolveS_singlePrecise -1 <R1.fq> -2 <R2.fq> [-o <output_file>]
#   Batch mode: ./resolveS_singlePrecise -b <metadata_file> [-o <output_file>]
#===============================================================================
export PS4='+ ${BASH_SOURCE}:${LINENO}: '
#set -x
#
set -e

# Default values
MODE=""
R1_FILE=""
R2_FILE=""
METADATA_FILE=""
OUTPUT_FILE="log.raw.SAM.counts.txt"
THREADS=6
MAX_ALIG_READS=10  # Precise version uses more reads (10M default)
MAX_ALIG_READS_ACTUAL=$((MAX_ALIG_READS * 1000000))
REFERENCE_DB="../ref_default/default"
REFERENCE_DB_IS_DEFAULT=true
DEBUG=false  # Debug mode: keep intermediate files
# Get the DIR of the SCRIPT
SCRIPT_DIR="$( cd "$( dirname "${BASH_SOURCE[0]}" )" &> /dev/null && pwd )"

# Color output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

#===============================================================================
# Functions
#===============================================================================

print_usage() {
    cat << 'EOF'
This is resolveS_singlePrecise version 0.1.1
Usage: $0 [OPTIONS]

Options:
    -1 <file>       R1 (first read) file for single sample mode
    -2 <file>       R2 (second read) file for single sample mode
    -b <file>       Batch mode: process multiple files from metadata file
    -c <file>       Output the count matrix from the SAM file (default: log.raw.SAM.counts.txt) debug option
    -p <number>     Number of threads to use (default: 6)
    -u <number>     Maximum number of read pairs to align, in millions (default: 10, i.e. 10M pairs)
    -r <path>       The reference genome db, can be any bowtie2 index (default: ../ref_default/default)
    -d              Debug mode: keep intermediate files (resolveS.sam, counts.txt)
    -h              Show this help message

Examples:
    # Single sample mode (paired-end)
    $0 -1 sample_R1.fastq -2 sample_R2.fastq

    # Batch mode with multiple threads
    $0 -b metadata.txt -p 8

    # Limit alignment to 4 million read pairs
    $0 -1 sample_R1.fastq -2 sample_R2.fastq -u 4

IMPORTANT: This is the PRECISE version - it uses more reads and provides
           1M incremental analysis for better accuracy.
           Uses paired-end alignment. For single-end data, use resolveS_fast.

Metadata file format (tab-separated: R1_path R2_path):
    /path/to/sample1_R1.fastq    /path/to/sample1_R2.fastq
    /path/to/sample2_R1.fq.gz    /path/to/sample2_R2.fq.gz

EOF
}

log_info() {
    local message="${1:-}"
    [[ -n "$message" ]] && echo -e "${GREEN}[INFO]${NC} $message" >&2
}

log_warn() {
    local message="${1:-}"
    [[ -n "$message" ]] && echo -e "${YELLOW}[WARN]${NC} $message" >&2
}

log_error() {
    local message="${1:-}"
    [[ -n "$message" ]] && echo -e "${RED}[ERROR]${NC} $message" >&2
}

check_dependencies() {
    local missing=0

    if [[ ! -f "${REFERENCE_DB}.1.bt2" ]]; then
        log_error "Can not found the bowtie2 genome index file: ${REFERENCE_DB}.1.bt2"
        log_error "Please check your -r parameter or download the default index from https://github.com/yudalang3/resolveS"
        missing=1
    fi

    # Shares alignment script with default version
    if [[ ! -f "${SCRIPT_DIR}/default_align_by_bowtie2.sh" ]]; then
        log_error "Required script not found: ${SCRIPT_DIR}/default_align_by_bowtie2.sh"
        missing=1
    fi

    if [[ ! -f "${SCRIPT_DIR}/precise_count_sam_1M_increase.sh" ]]; then
        log_error "Required script not found: ${SCRIPT_DIR}/precise_count_sam_1M_increase.sh"
        missing=1
    fi

    if [[ ! -f "${SCRIPT_DIR}/precise_check_strand_step1M_withCount.py" ]]; then
        log_error "Required script not found: ${SCRIPT_DIR}/precise_check_strand_step1M_withCount.py"
        missing=1
    fi

    # Also needs fast_check_strand.py for shared functions
    if [[ ! -f "${SCRIPT_DIR}/fast_check_strand.py" ]]; then
        log_error "Required script not found: ${SCRIPT_DIR}/fast_check_strand.py"
        missing=1
    fi

    if [[ $missing -eq 1 ]]; then
        exit 1
    fi
}

process_single_sample() {
    local r1="$1"
    local r2="$2"
    local output="$3"
    local threads="$4"
    local max_alig_reads="$5"

    if [[ ! -f "$r1" ]]; then
        log_error "R1 file not found: $r1"
        return 1
    fi

    if [[ ! -f "$r2" ]]; then
        log_error "R2 file not found: $r2"
        return 1
    fi

    log_info "Processing paired-end (PRECISE): $r1 + $r2 (threads: $threads, max_pairs: ${MAX_ALIG_READS}M, reference: $REFERENCE_DB)"

    # Step 1: Run paired-end alignment (shared with default version)
    "${SCRIPT_DIR}/default_align_by_bowtie2.sh" "$r1" "$r2" "$REFERENCE_DB" "$threads" "$max_alig_reads"

    # Get basename for logging (use R1 as identifier)
    local fullpath=$(realpath "$r1")

    # Step 2: Count SAM file with 1M increments
    "${SCRIPT_DIR}/precise_count_sam_1M_increase.sh" resolveS.sam "$output" "$fullpath" "$MAX_ALIG_READS"

    return 0
}

process_batch() {
    local metadata="$1"
    local output_file="$2"
    local threads="$3"
    local max_alig_reads="$4"

    if [[ ! -f "$metadata" ]]; then
        log_error "Metadata file not found: $metadata"
        exit 1
    fi

    # Count non-empty, non-comment lines
    local total_lines=$(grep -v '^[[:space:]]*#' "$metadata" | grep -v '^[[:space:]]*$' | wc -l)

    local current=0
    local success=0
    local failed=0

    log_info "Starting batch processing (PRECISE) of $total_lines samples (threads: $threads, max_pairs: ${MAX_ALIG_READS}M)"

    while IFS=$'\t' read -r r1_file r2_file || [[ -n "$r1_file" ]]; do
        # Skip empty lines
        if [[ -z "$r1_file" ]]; then
            continue
        fi
        # Skip comments
        if [[ "$r1_file" =~ ^# ]]; then
            continue
        fi

        ((current++)) || true
        log_info "Processing sample $current/$total_lines"

        process_single_sample "$r1_file" "$r2_file" "$output_file" "$threads" "$max_alig_reads"
        local result=$?

        if [[ $result -eq 0 ]]; then
            ((success++)) || true
        else
            ((failed++)) || true
            log_error "Failed to process: $r1_file"
        fi

    done < "$metadata"

    log_info "Batch processing completed!"
    log_info "Total: $total_lines | Success: $success | Failed: $failed"
}

#===============================================================================
# Main
#===============================================================================

# Parse command line arguments
while getopts "1:2:b:c:p:u:r:dh" opt; do
    case $opt in
        1)
            MODE="single"
            R1_FILE="$OPTARG"
            ;;
        2)
            R2_FILE="$OPTARG"
            ;;
        b)
            MODE="batch"
            METADATA_FILE="$OPTARG"
            ;;
        c)
            OUTPUT_FILE="$OPTARG"
            ;;
        p)
            THREADS="$OPTARG"
            if ! [[ "$THREADS" =~ ^[0-9]+$ ]] || [[ "$THREADS" -lt 1 ]]; then
                log_error "Invalid thread number: $THREADS (must be a positive integer)"
                exit 1
            fi
            ;;
        u)
            MAX_ALIG_READS="$OPTARG"
            if ! [[ "$MAX_ALIG_READS" =~ ^[0-9]+$ ]] || [[ "$MAX_ALIG_READS" -lt 1 ]]; then
                log_error "Invalid -u value: $MAX_ALIG_READS (must be a positive integer, unit: millions)"
                exit 1
            fi
            MAX_ALIG_READS_ACTUAL=$((MAX_ALIG_READS * 1000000))
            ;;
        r)
            REFERENCE_DB="$OPTARG"
            REFERENCE_DB_IS_DEFAULT=false
            ;;
        d)
            DEBUG=true
            ;;
        h)
            print_usage
            exit 0
            ;;
        \?)
            log_error "Invalid option: -$OPTARG"
            print_usage
            exit 1
            ;;
    esac
done

# Normalize REFERENCE_DB to absolute path
if [[ "$REFERENCE_DB" != /* ]]; then
    if [[ "$REFERENCE_DB_IS_DEFAULT" == true ]]; then
        REFERENCE_DB="${SCRIPT_DIR}/${REFERENCE_DB}"
    else
        if [[ -d "$(dirname "$REFERENCE_DB")" ]]; then
            REFERENCE_DB="$(cd "$(dirname "$REFERENCE_DB")" && pwd)/$(basename "$REFERENCE_DB")"
        else
            REFERENCE_DB="$(pwd)/$REFERENCE_DB"
        fi
    fi
fi

# Check if mode is specified
if [[ -z "$MODE" ]]; then
    log_error "Please specify either -1/-2 (single sample) or -b (batch) mode"
    print_usage
    exit 1
fi

# Check dependencies
check_dependencies

# Execute based on mode
case $MODE in
    single)
        if [[ -z "$R1_FILE" ]] || [[ -z "$R2_FILE" ]]; then
            log_error "Both -1 (R1) and -2 (R2) files must be specified for single sample mode"
            exit 1
        fi
        process_single_sample "$R1_FILE" "$R2_FILE" "$OUTPUT_FILE" "$THREADS" "$MAX_ALIG_READS_ACTUAL"
        ;;
    batch)
        if [[ -z "$METADATA_FILE" ]]; then
            log_error "Metadata file not specified for batch mode"
            exit 1
        fi
        process_batch "$METADATA_FILE" "$OUTPUT_FILE" "$THREADS" "$MAX_ALIG_READS_ACTUAL"
        ;;
esac


python3 ${SCRIPT_DIR}/precise_check_strand_step1M_withCount.py $OUTPUT_FILE

# Clean up (skip if debug mode)
if [[ "$DEBUG" == false ]]; then
    if [[ -f resolveS.sam ]]; then
        rm resolveS.sam
        log_info "Cleaned up temporary file: resolveS.sam"
    fi

    if [[ -f $OUTPUT_FILE ]]; then
        rm $OUTPUT_FILE
        log_info "Cleaned up temporary file: $OUTPUT_FILE"
    fi
else
    log_info "Debug mode: keeping intermediate files (resolveS.sam, $OUTPUT_FILE)"
fi

log_info "All done!"

exit 0
